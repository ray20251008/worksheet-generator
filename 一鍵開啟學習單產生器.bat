@echo off
chcp 950 > nul
title 華聖家園瑞翔日間作業所 - 學習單產生器
echo ====================================================================
echo   華聖家園瑞翔日間作業所 - 學習單智慧產生器 (特教圖卡雙模版)
echo ====================================================================
echo.
echo 正在偵測伺服器狀態並為您準備網頁環境...
echo.

:: 檢查 7788 連接埠是否已被佔用
netstat -ano | findstr "7788" > nul
if %errorlevel% neq 0 (
    echo [系統提示] 偵測到伺服器尚未啟動，正在背景為您建立離線網頁服務...
    start /b python -m http.server 7788
    timeout /t 2 /nobreak > nul
) else (
    echo [系統提示] 離線伺服器已在運行中，無需重複啟動！
)

echo.
echo [系統提示] 正在自動為您開啟瀏覽器載入學習單頁面...
start http://localhost:7788/index.html
echo.
echo ====================================================================
echo   啟動成功！學習單編輯視窗已在您的預設瀏覽器中開啟。
echo   溫馨提醒：使用期間請保持此視窗開啟，編輯完成後直接關閉視窗即可。
echo ====================================================================
echo.
timeout /t 5 > nul
exit
